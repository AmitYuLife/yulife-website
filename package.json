{
  "name": "yulife-website-2026",
  "version": "0.1.0",
  "private": true,
  "description": "YuLife 2026 website redesign. Next.js + Tailwind, structured for React Bricks.",
  "scripts": {
    "dev": "NEXT_DIST_DIR=.next-dev next dev --turbopack",
    "build": "rm -rf .next out && next build",
    "start": "next start",
