    "gen:pages": "tsx scripts/generate-pages.mjs",
    "gen:svg": "tsx scripts/generate-sitemap-svg.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@gsap/react": "^2.1.2",
    "@tailwindcss/postcss": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.18.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
