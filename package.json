{
  "name": "yulife-website-2026",
  "version": "0.1.0",
  "private": true,
  "description": "YuLife 2026 website redesign. Next.js + Tailwind, structured for React Bricks.",
  "scripts": {
    "dev": "NEXT_DIST_DIR=.next-dev next dev --turbopack",
    "build": "rm -rf .next out && next build",
    "start": "next start",
    "clean": "rm -rf .next .next-dev out",
    "lint": "next lint",
    "gen:pages": "tsx scripts/generate-pages.mjs",
    "gen:svg": "tsx scripts/generate-sitemap-svg.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/postcss": "^4.3.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.4.9",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/three": "^0.185.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
